MONGODB_URI=mongodb://127.0.0.1:27017/pgfinder
PORT=5001
JWT_SECRET=replace-with-long-random-secret
NODE_ENV=development
CORS_ORIGIN=*

# Express JSON body size (e.g. 1mb, 512kb)
BODY_PARSER_LIMIT=1mb

# Chat / stored messages
MESSAGE_MAX_LENGTH=8000

# Register: minimum password length
PASSWORD_MIN_LENGTH=8

# POST /api/auth/register and /login
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100
BCRYPT_SALT_ROUNDS=10
JWT_EXPIRES_IN=7d

# GET /api/property pagination (defaults & upper clamp)
PROPERTY_PAGINATION_DEFAULT=10
PROPERTY_PAGINATION_MAX=50

# GET /api/messages pagination
MESSAGE_PAGINATION_DEFAULT=10
MESSAGE_PAGINATION_MAX=100
